{
    "name": "@mfp-design-system/layout",
    "version": "0.1.0",
    "description": "Layout primitives (container, row, col) and a spacing/flex utility sheet for the mfp-design-system.",
    "license": "MIT",
    "type": "module",
    "sideEffects": [
        "dist/index.js",
        "dist/container.js",
        "dist/row.js",
        "dist/col.js",
        "*.css"
    ],
    "files": [
        "dist",
        "src",
        "README.md"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./utilities.css": "./dist/utilities.css"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc -p tsconfig.build.json && node scripts/copy-css.mjs",
        "dev": "tsc -p tsconfig.build.json --watch",
        "clean": "rimraf dist",
        "lint": "eslint . --max-warnings=0",
        "typecheck": "tsc --noEmit",
        "test": "echo \"tests run from workspace root\""
    },
    "dependencies": {
        "lit": "^3.2.1"
    },
    "peerDependencies": {
        "@mfp-design-system/tokens": "^0.8.0"
    },
    "peerDependenciesMeta": {
        "@mfp-design-system/tokens": {
            "optional": true
        }
    },
    "devDependencies": {
        "@mfp-design-system/tokens": "workspace:*",
        "rimraf": "^6.0.1",
        "typescript": "^5.6.3"
    },
    "publishConfig": {
        "access": "public"
    }
}
