{
    "name": "@mfp-design-system/tokens",
    "version": "0.2.0",
    "description": "Design tokens for the mfp-design-system, built with Style Dictionary.",
    "license": "MIT",
    "type": "module",
    "sideEffects": [
        "*.css"
    ],
    "files": [
        "build",
        "README.md"
    ],
    "exports": {
        ".": {
            "types": "./build/ts/tokens.d.ts",
            "import": "./build/js/tokens.js",
            "default": "./build/js/tokens.js"
        },
        "./css": {
            "default": "./build/css/tokens.css"
        },
        "./json": {
            "default": "./build/json/tokens.json"
        },
        "./themes/blue": "./build/themes/blue.css",
        "./themes/warm": "./build/themes/warm.css",
        "./themes/orange": "./build/themes/orange.css",
        "./themes/earth": "./build/themes/earth.css",
        "./themes/portfolio": "./build/themes/portfolio.css"
    },
    "main": "./build/js/tokens.js",
    "module": "./build/js/tokens.js",
    "types": "./build/ts/tokens.d.ts",
    "scripts": {
        "build": "node scripts/build.mjs",
        "dev": "node scripts/build.mjs --watch",
        "clean": "rimraf build",
        "lint": "eslint . --max-warnings=0",
        "typecheck": "tsc --noEmit",
        "test": "echo \"no tests yet\""
    },
    "devDependencies": {
        "rimraf": "^6.0.1",
        "style-dictionary": "^4.2.0",
        "typescript": "^5.6.3"
    },
    "publishConfig": {
        "access": "public"
    }
}
