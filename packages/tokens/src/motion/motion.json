{
    "motion": {
        "duration": {
            "instant": { "$value": "0ms", "$type": "duration" },
            "fast": { "$value": "150ms", "$type": "duration" },
            "normal": { "$value": "200ms", "$type": "duration" },
            "slow": { "$value": "300ms", "$type": "duration" },
            "slower": { "$value": "500ms", "$type": "duration" }
        },
        "easing": {
            "linear": { "$value": "cubic-bezier(0, 0, 1, 1)", "$type": "string" },
            "standard": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "string" },
            "accelerate": { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "string" },
            "decelerate": { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$type": "string" },
            "spring": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "string" }
        }
    }
}
