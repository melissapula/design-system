{
    "name": "@mfp-design-system/all",
    "version": "4.0.6",
    "description": "Meta-package — depends on and re-exports every component. One install gets the whole design system.",
    "license": "MIT",
    "type": "module",
    "sideEffects": true,
    "files": [
        "dist",
        "src",
        "README.md"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "dev": "tsc -p tsconfig.build.json --watch",
        "clean": "rimraf dist",
        "lint": "eslint . --max-warnings=0",
        "typecheck": "tsc --noEmit",
        "test": "echo \"tests run from workspace root\""
    },
    "dependencies": {
        "@mfp-design-system/accordion": "workspace:*",
        "@mfp-design-system/alert": "workspace:*",
        "@mfp-design-system/avatar": "workspace:*",
        "@mfp-design-system/badge": "workspace:*",
        "@mfp-design-system/button": "workspace:*",
        "@mfp-design-system/card": "workspace:*",
        "@mfp-design-system/checkbox": "workspace:*",
        "@mfp-design-system/divider": "workspace:*",
        "@mfp-design-system/footer": "workspace:*",
        "@mfp-design-system/form-field": "workspace:*",
        "@mfp-design-system/icon-button": "workspace:*",
        "@mfp-design-system/input": "workspace:*",
        "@mfp-design-system/modal": "workspace:*",
        "@mfp-design-system/nav": "workspace:*",
        "@mfp-design-system/radio": "workspace:*",
        "@mfp-design-system/select": "workspace:*",
        "@mfp-design-system/spinner": "workspace:*",
        "@mfp-design-system/stepper": "workspace:*",
        "@mfp-design-system/switch": "workspace:*",
        "@mfp-design-system/tabs": "workspace:*",
        "@mfp-design-system/textarea": "workspace:*",
        "@mfp-design-system/toast": "workspace:*",
        "@mfp-design-system/tooltip": "workspace:*"
    },
    "peerDependencies": {
        "@mfp-design-system/tokens": "workspace:^"
    },
    "peerDependenciesMeta": {
        "@mfp-design-system/tokens": {
            "optional": true
        }
    },
    "devDependencies": {
        "rimraf": "^6.0.1",
        "typescript": "^5.6.3"
    },
    "publishConfig": {
        "access": "public"
    }
}
